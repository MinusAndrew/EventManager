<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<TabPane side="LEFT" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.eventmanager.viewController.MainView">
   <tabs>
      <Tab closable="false" text="Main Menu">
         <content>
            <AnchorPane fx:id="scenePane" prefHeight="414.0" prefWidth="726.0">
               <children>
                  <TableView fx:id="eventTable" layoutX="62.0" layoutY="78.0" prefHeight="200.0" prefWidth="604.0">
                    <columns>
                      <TableColumn fx:id="nameColumn" prefWidth="104.0" text="Nombre" />
                      <TableColumn fx:id="cityColumn" prefWidth="95.0" text="Ciudad" />
                        <TableColumn fx:id="dateColumn" prefWidth="106.0" text="Fecha" />
                        <TableColumn fx:id="placeColumn" prefWidth="104.0" text="Lugar" />
                        <TableColumn fx:id="typeColumn" prefWidth="95.0" text="Tipo" />
                        <TableColumn fx:id="statusColumn" prefWidth="99.0" text="Estado" />
                    </columns>
                  </TableView>
                  <Text layoutX="205.0" layoutY="48.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Encuentra el evento que necesitas aquí!" textAlignment="CENTER" wrappingWidth="316.54736328125" />
                  <ChoiceBox fx:id="typeChoiceBox" layoutX="289.0" layoutY="310.0" prefWidth="150.0" />
                  <ChoiceBox fx:id="statusChoiceBox" layoutX="516.0" layoutY="310.0" prefWidth="150.0" />
                  <TextField fx:id="cityField" layoutX="71.0" layoutY="310.0" promptText="Pon tu ciudad aqui!" />
                  <Button layoutX="448.0" layoutY="360.0" mnemonicParsing="false" onAction="#fillUpFilteredEventList" text="Buscar" />
                  <Text layoutX="71.0" layoutY="298.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Ciudad" />
                  <Text layoutX="288.0" layoutY="298.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Tipo" />
                  <Text layoutX="522.0" layoutY="298.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Estado" />
                  <Button layoutX="223.0" layoutY="360.0" mnemonicParsing="false" onAction="#buyEventAction" text="Comprar" />
                  <Button layoutX="334.0" layoutY="360.0" mnemonicParsing="false" onAction="#checkEventDetailsAction" text="Detalles" />
               </children>
            </AnchorPane>
         </content>
      </Tab>
      <Tab closable="false" onSelectionChanged="#refreshCartAction" text="Carrito">
          <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                  <children>
                      <TableView fx:id="cartTable" layoutX="62.0" layoutY="78.0" prefHeight="200.0" prefWidth="604.0">
                          <columns>
                              <TableColumn fx:id="cartEventColumn" prefWidth="150.0" text="Evento" />
                              <TableColumn fx:id="cartTotalColumn" prefWidth="100.0" text="Total" />
                              <TableColumn fx:id="cartPaymentColumn" prefWidth="150.0" text="Método Pago" />
                              <TableColumn fx:id="cartTicketsColumn" prefWidth="100.0" text="Entradas" />
                          </columns>
                      </TableView>
                      <Text layoutX="205.0" layoutY="48.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Tu Carrito de Compras" textAlignment="CENTER" wrappingWidth="316.54736328125" />
                      <Button layoutX="100.0" layoutY="310.0" mnemonicParsing="false" onAction="#processCartAction" text="Procesar Compra" />
                      <Button layoutX="330.0" layoutY="310.0" mnemonicParsing="false" onAction="#editCartAction" text="Modificar" />
                      <Button layoutX="500.0" layoutY="310.0" mnemonicParsing="false" onAction="#deleteCartAction" text="Eliminar del Carrito" />
                  </children>
              </AnchorPane>
          </content>
      </Tab>
      <Tab closable="false" onSelectionChanged="#refreshUserTabAction" text="User">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <Button layoutX="25.0" layoutY="362.0" mnemonicParsing="false" onAction="#logoutAction" text="logout" />
                  <TextField fx:id="nameField" layoutX="535.0" layoutY="49.0" />
                  <TextField fx:id="emailField" layoutX="535.0" layoutY="126.0" />
                  <TextField fx:id="phoneField" layoutX="535.0" layoutY="194.0" />
                  <Text layoutX="403.0" layoutY="67.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Nombre Completo" />
                  <Text layoutX="439.0" layoutY="144.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email" />
                  <Text layoutX="429.0" layoutY="212.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Telefono" />
                  <Text fx:id="userDataText" layoutX="14.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="User Data:" wrappingWidth="406.21630859375" />
                  <TextField fx:id="passwordField" layoutX="535.0" layoutY="267.0" />
                  <Text layoutX="421.0" layoutY="285.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña:" />
                  <Button layoutX="587.0" layoutY="349.0" mnemonicParsing="false" onAction="#updateUserAction" text="Aplicar" />
                  <TableView fx:id="historyTable" layoutX="14.0" layoutY="131.0" prefHeight="200.0" prefWidth="376.0">
                    <columns>
                      <TableColumn fx:id="historyIdPurchaseColumn" prefWidth="75.0" text="Id Compra" />
                        <TableColumn fx:id="historyDateColumn" prefWidth="75.0" text="Fecha" />
                        <TableColumn fx:id="historyTotalColumn" prefWidth="75.0" text="Total" />
                        <TableColumn fx:id="historyPaymentColumn" prefWidth="75.0" text="Pago" />
                      <TableColumn fx:id="historyTicketsColumn" prefWidth="75.0" text="Nro Tickets" />
                    </columns>
                  </TableView>
                  <Text layoutX="14.0" layoutY="122.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Historial de compras:" />
               </children>
            </AnchorPane>
        </content>
      </Tab>
   </tabs>
</TabPane>
