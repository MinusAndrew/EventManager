<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="560.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.eventmanager.viewController.PurchaseView">
    <children>
        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backAction" text="Back" />
        
        <Text fx:id="eventNameText" layoutX="100.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Event Name" wrappingWidth="500.0">
            <font>
                <Font size="24.0" />
            </font>
        </Text>
        
        <Label layoutX="30.0" layoutY="70.0" text="Seleccionar Zona:" />
        <ChoiceBox fx:id="zoneChoiceBox" layoutX="140.0" layoutY="65.0" prefWidth="200.0" />

        <Label layoutX="30.0" layoutY="110.0" text="Seleccionar Sillas:" />
        <ScrollPane fx:id="chairsScrollPane" layoutX="30.0" layoutY="130.0" prefHeight="250.0" prefWidth="640.0">
            <content>
                <GridPane fx:id="chairsGrid" hgap="10" vgap="10" alignment="CENTER">
                    <!-- Chairs will be dynamically added here -->
                </GridPane>
            </content>
        </ScrollPane>
        <Label fx:id="noChairsLabel" layoutX="200.0" layoutY="240.0" text="No aplica para esta zona" visible="false" style="-fx-font-size: 18px; -fx-text-fill: #888888; -fx-font-style: italic;" />

        <Label layoutX="30.0" layoutY="390.0" text="Servicios Adicionales:" style="-fx-font-weight: bold;" />
        <CheckBox fx:id="cateringCheck" layoutX="30.0" layoutY="410.0" text="Catering ($50,000)" onAction="#updateTotalCost" />
        <CheckBox fx:id="insuranceCheck" layoutX="200.0" layoutY="410.0" text="Seguro ($15,000)" onAction="#updateTotalCost" />
        <CheckBox fx:id="merchandisingCheck" layoutX="370.0" layoutY="410.0" text="Merchandising ($25,000)" onAction="#updateTotalCost" />
        <CheckBox fx:id="parkingCheck" layoutX="30.0" layoutY="435.0" text="Parqueadero ($10,000)" onAction="#updateTotalCost" />
        <CheckBox fx:id="preferentialCheck" layoutX="200.0" layoutY="435.0" text="Acceso Preferencial ($30,000)" onAction="#updateTotalCost" />

        <Label layoutX="30.0" layoutY="470.0" text="Método de Pago:" />
        <ChoiceBox fx:id="paymentTypeChoiceBox" layoutX="140.0" layoutY="465.0" prefWidth="150.0" />

        <Text layoutX="350.0" layoutY="483.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Total: $" />
        <Text fx:id="totalCostText" layoutX="400.0" layoutY="483.0" strokeType="OUTSIDE" strokeWidth="0.0" text="0.0">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Text>

        <Button fx:id="payButton" layoutX="550.0" layoutY="465.0" mnemonicParsing="false" onAction="#payAction" prefHeight="40.0" prefWidth="100.0" text="Guardar" />
    </children>
</AnchorPane>
